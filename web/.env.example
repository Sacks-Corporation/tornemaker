# ─── API ───────────────────────────────────────────────────────────────────────
# URL base de la API de Tornemaker.
VITE_API_BASE_URL=http://localhost:3000/api

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# ID de cliente de OAuth obtenido en Google Cloud Console.
# Es el mismo valor que GOOGLE_CLIENT_ID en la API.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
