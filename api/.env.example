# ─── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/tornemaker?retryWrites=true&w=majority

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# The OAuth 2.0 Client ID obtained from Google Cloud Console.
# Used to verify Google ID tokens sent by the frontend.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Secret key used to sign and verify our own JWTs.
# Use a long, random, cryptographically secure string.
JWT_SECRET=replace-with-a-strong-random-secret

# JWT expiration time (e.g. 7d, 24h, 3600s).
JWT_EXPIRES_IN=7d

# ─── App ───────────────────────────────────────────────────────────────────────
PORT=3000
